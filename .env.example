# ── Notion ─────────────────────────────────────────────────────
# Internal integration token (Notion → Settings → Connections → Develop integrations).
# Share ONLY these databases with the integration:
#   User, 🏨 Hotel Vault, ⭐ STR Data, 💵 Sales Pipeline, 🏭 Target Companies
# Leave NOTION_TOKEN empty to run in DEMO MODE (sample portfolio, any email signs in).
NOTION_TOKEN=

# Database IDs (the 32-char hex in each database's URL)
NOTION_DB_USER=2937f55b8025807c9eecec47553089f2
NOTION_DB_HOTEL_VAULT=
NOTION_DB_STR=
NOTION_DB_PIPELINE=
NOTION_DB_TARGETS=
# Optional — for pulling #weekly salary per hotel:
NOTION_DB_SALES_CALLS=

# ── Auth.js ────────────────────────────────────────────────────
# Generate with:  npx auth secret   (or any long random string)
AUTH_SECRET=

# Resend (magic-link email) — production only. https://resend.com
AUTH_RESEND_KEY=
EMAIL_FROM="Hotel Sales Edge <portal@hotelsalesedge.com>"

# Local dev
NEXTAUTH_URL=http://localhost:3000
